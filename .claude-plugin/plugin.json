{
  "name": "upublish",
  "version": "0.12.6",
  "description": "Publish static sites to upubli.sh instantly. One directory becomes a live URL.",
  "author": {
    "name": "omni-ping"
  },
  "mcpServers": {
    "upublish": {
      "command": "sh",
      "args": [
        "-c",
        "exec bun run \"${CLAUDE_PLUGIN_ROOT}/dist/mcp.js\""
      ]
    }
  }
}
