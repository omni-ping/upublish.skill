{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "types": ["bun"]
  },
  "include": ["lib/**/*.ts", "bin/**/*.ts", "mcp/**/*.ts", "tests/**/*.ts"]
}
